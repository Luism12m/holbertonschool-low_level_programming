#include "main.h"
/**
 * print_sign - Check the sign of a number.
 * @n: The character to be checked.
 * Description: This function prints the sign of a number
 *
 * Return: 1  and prints "+" if n is greater than 0,
   Return: 0  and prints "0" if n is 0,
   Return: -1  and prints "-" if n is less than 0,
*/

int print_sign(int n)
{
  
  if (n > 0)
    {
      _putchar(43);
      return (1);
    }
  else if (n = 0)
    {
      _putchar(48);
      return (-1);
    }
  else 
	 {
	 _putchar(45);
	 }
  return (0);
}
